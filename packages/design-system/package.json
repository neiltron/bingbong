{
  "name": "@bingbong/design-system",
  "version": "0.1.0",
  "private": true,
  "description": "React components for the bingbong design system (teal/marigold/rose/cream, Geist Mono + Inter)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cat src/styles.css ../../apps/client/src/styles/design-system.css > dist/styles.css"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.3.0"
  }
}
